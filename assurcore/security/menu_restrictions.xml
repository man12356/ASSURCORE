<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!--
  ================================================================================
    AssurCore — Restrictions de menus UI (security/menu_restrictions.xml)

    Objectifs :
      1. Masquer le menu "Apps" (installation de modules) à tous les utilisateurs
         sauf les administrateurs techniques (base.group_erp_manager).
         → Les responsables AssurCore peuvent gérer les utilisateurs et la
           configuration via Paramètres SANS pouvoir installer des modules.

      2. Masquer le menu "Parc automobile" (Fleet) root aux agents AssurCore.
         → Les données de véhicules restent accessibles depuis les polices
           AssurCore mais pas via le module Fleet natif.

    Architecture de groupes AssurCore :
      group_assurcore_agent   → Agent de saisie  (implied: base.group_user)
      group_assurcore_manager → Responsable      (implied: group_assurcore_agent)

    RÈGLE ODOO : un menu avec un groups_id est visible UNIQUEMENT aux membres
    de ce groupe. Sans groups_id = visible à tous les utilisateurs internes.
  ================================================================================
  -->

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!--  1. MASQUAGE DU MENU "APPS" (module store)                            -->
  <!--     Réservé aux administrateurs techniques uniquement                  -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <!-- Menu racine "Apps" (affiché dans la barre de navigation principale) -->
  <record id="base.menu_management" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [ref('group_apps_manager')])]"/>
  </record>

  <!-- Menu "Apps" dans la barre supérieure (l'autre entrée) -->
  <record id="base.menu_apps" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [ref('group_apps_manager')])]"/>
  </record>

  <!-- Sous-menus Apps : Applications principales, Applications tierces, Mise à jour -->
  <record id="base.menu_module_tree" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [ref('group_apps_manager')])]"/>
  </record>

  <record id="base.menu_third_party" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [ref('group_apps_manager')])]"/>
  </record>

  <record id="base.menu_view_base_module_update" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [ref('group_apps_manager')])]"/>
  </record>


  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!--  2. MASQUAGE DU MENU "PARC AUTOMOBILE" (Fleet) pour les agents        -->
  <!--     Réservé aux gestionnaires de flotte uniquement                     -->
  <!--     Les agents AssurCore n'ont PAS le groupe fleet.fleet_group_user   -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <!-- Menu racine "Parc automobile" → visible uniquement aux gestionnaires Fleet -->
  <record id="fleet.menu_root" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [ref('fleet.fleet_group_manager')])]"/>
  </record>


  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!--  3. MENU "PARC AUTOMOBILE" dans AssurCore Paramétrage                  -->
  <!--     → Visible uniquement au groupe Responsable AssurCore               -->
  <!--       (pas aux agents de saisie)                                       -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <record id="menu_assurcore_fleet_vehicle" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [ref('group_assurcore_manager')])]"/>
  </record>

</odoo>
