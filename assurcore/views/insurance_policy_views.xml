<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!--  VUE FORM — Police d'Assurance                                         -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <record id="view_insurance_policy_form" model="ir.ui.view">
    <field name="name">insurance.policy.form</field>
    <field name="model">insurance.policy</field>
    <field name="arch" type="xml">
      <form string="Police d'Assurance">

        <header>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft_ocr,draft,active,unpaid"/>

          <!-- ── Bouton Wizard OCR (EVO01 Étape 3) ────────────────────── -->
          <!-- Visible uniquement pour les brouillons générés par OCR       -->
          <!-- Ouvre insurance.ocr.wizard en popup pour valider le client   -->
          <button name="action_open_ocr_wizard"
                  string="Valider les données OCR"
                  type="object"
                  class="oe_highlight btn-warning"
                  invisible="state != 'draft_ocr'"
                  help="Ouvre le wizard pour identifier ou créer le client assuré."/>

          <!-- ── Bouton de test OCR (développement/recette) ────────────── -->
          <!-- Simule la réception d'un email PDF sans alias mail            -->
          <button name="action_test_ocr"
                  string="Simuler Réception OCR"
                  type="object"
                  class="btn-secondary"
                  invisible="state != 'draft_ocr'"
                  help="Teste le workflow OCR directement depuis la fiche police (Phase 1 — mock)."/>

          <button name="action_activate" string="Activer"
                  type="object" class="btn-primary"
                  invisible="state != 'draft'"/>
          <button name="action_send_renewal_email"
                  string="📧 Envoyer Relance E-mail"
                  type="object" class="btn-secondary"
                  invisible="state not in ('active','unpaid','expired')"
                  help="Envoie immédiatement l'e-mail de relance renouvellement à l'assuré."/>
          <button name="action_cancel" string="Résilier"
                  type="object" class="btn-secondary"
                  invisible="state not in ('active','unpaid')"/>
          <button name="action_reopen" string="Réouvrir"
                  type="object" class="btn-secondary"
                  invisible="state not in ('canceled','expired')"/>
        </header>

        <!-- Ruban OCR — violet/info pour signaler une police non encore validée -->
        <div class="oe_ribbon"
             style="background-color: #7c3aed; color: white;"
             invisible="state != 'draft_ocr'">
          <span>Brouillon OCR</span>
        </div>

        <div class="oe_ribbon oe_ribbon_warning"
             invisible="state != 'unpaid'">
          <span>Impayée</span>
        </div>
        <div class="oe_ribbon"
             invisible="state != 'expired'">
          <span>Expirée</span>
        </div>

        <sheet>
          <div name="button_box" class="oe_button_box">
            <button name="action_view_receipts" type="object"
                    class="oe_stat_button" icon="fa-list-alt">
              <field name="receipt_count" widget="statinfo" string="Quittances"/>
            </button>
            <button name="action_view_claims" type="object"
                    class="oe_stat_button" icon="fa-ambulance"
                    invisible="claim_count == 0">
              <field name="claim_count" widget="statinfo" string="Sinistres"/>
            </button>
            <button name="action_view_operations" type="object"
                    class="oe_stat_button" icon="fa-exchange"
                    invisible="operation_count == 0">
              <field name="operation_count" widget="statinfo" string="Opérations"/>
            </button>
          </div>

          <div class="oe_title">
            <label for="num_police"/>
            <h1>
              <field name="num_police" placeholder="N° Police"/>
            </h1>
            <div>
              <field name="company_ins_id" options="{'no_create': True}"
                     class="badge"/>
              <field name="branche" class="badge badge-secondary ms-1"/>
            </div>
          </div>

          <!-- Indicateur financier -->
          <div class="alert alert-danger" role="alert"
               invisible="total_impaye == 0">
            <strong>Impayé : </strong>
            <field name="total_impaye" widget="monetary"
                   options="{'currency_field': 'currency_id'}"/> TND
          </div>

          <group>
            <group string="Assuré">
              <field name="partner_id" options="{'no_create': True}"/>
              <field name="payer_id" options="{'no_create': True}"
                     invisible="payer_id == partner_id"/>
              <field name="raison_sociale"/>
              <field name="type_client"/>
            </group>
            <group string="Contrat">
              <field name="company_ins_id" options="{'no_create': True}"/>
              <field name="branche"/>
              <field name="risque"/>
              <field name="commercial_id" options="{'no_create': True}"/>
              <field name="agence_courtier"/>
            </group>
          </group>
          <group>
            <group string="Validité">
              <field name="date_effect"/>
              <field name="date_echeance"/>
              <field name="jours_avant_echeance" invisible="state == 'canceled'"/>
            </group>
            <group string="Financier">
              <field name="prime_nette" widget="monetary"
                     options="{'currency_field': 'currency_id'}"/>
              <field name="commission" widget="monetary"
                     options="{'currency_field': 'currency_id'}"/>
              <field name="taux_commission" widget="percentage"/>
              <field name="commission_rule_id" readonly="1"
                     invisible="commission_rule_id == False"/>
            </group>
          </group>

          <group string="Véhicule" invisible="branche != 'AUTO'">
            <field name="matricule"/>
            <field name="vehicle_id" options="{'no_create': True}"/>
          </group>

          <notebook>
            <page string="Quittances" name="quittances">
              <field name="receipt_ids" mode="tree" readonly="1">
                <tree decoration-danger="state == 'contentieux'"
                      decoration-warning="state in ('partielle','notifiee')"
                      decoration-success="state in ('encaissee','reversee')">
                  <field name="name"/>
                  <field name="date_emission"/>
                  <field name="date_echeance"/>
                  <field name="amount_total" widget="monetary"
                         options="{'currency_field': 'currency_id'}"/>
                  <field name="amount_residual" widget="monetary"
                         options="{'currency_field': 'currency_id'}"
                         decoration-danger="amount_residual &gt; 0"/>
                  <field name="jours_retard"
                         decoration-danger="jours_retard &gt; 60"
                         decoration-warning="jours_retard &gt; 30"/>
                  <field name="state" widget="badge"
                         decoration-success="state in ('encaissee','reversee')"
                         decoration-danger="state == 'contentieux'"
                         decoration-warning="state == 'partielle'"
                         decoration-info="state in ('emise','notifiee')"/>
                  <field name="currency_id" column_invisible="1"/>
                </tree>
              </field>
            </page>
            <page string="Sinistres" name="sinistres">
              <field name="claim_ids" mode="tree" readonly="1">
                <tree decoration-success="state == 'regle'"
                      decoration-muted="state == 'clos'">
                  <field name="name"/>
                  <field name="date_sinistre" widget="date"/>
                  <field name="categorie_indemnisation"/>
                  <field name="montant_reclame" widget="monetary"
                         options="{'currency_field': 'currency_id'}"/>
                  <field name="montant_indemnite" widget="monetary"
                         options="{'currency_field': 'currency_id'}"/>
                  <field name="state" widget="badge"/>
                  <field name="currency_id" column_invisible="1"/>
                </tree>
              </field>
            </page>
            <!-- Onglet OCR — visible uniquement pour les brouillons OCR -->
            <page string="Données OCR brutes" name="ocr_data"
                  invisible="state != 'draft_ocr'">
              <div class="alert alert-warning" role="alert">
                <i class="fa fa-exclamation-triangle me-2"/>
                Ce brouillon a été créé automatiquement par OCR.
                Utilisez le bouton <strong>"Valider les données OCR"</strong>
                pour associer le bon client et activer la police.
              </div>
              <group string="Informations extraites par l'IA">
                <group>
                  <field name="ocr_raw_company_type" readonly="1"/>
                  <field name="ocr_raw_partner_name" readonly="1"/>
                  <field name="ocr_raw_cin" readonly="1"
                         invisible="ocr_raw_company_type == 'company'"/>
                  <field name="ocr_raw_matricule_fiscal" readonly="1"
                         invisible="ocr_raw_company_type != 'company'"/>
                </group>
                <group>
                  <field name="document_parser_id" readonly="1"
                         options="{'no_create': True}"/>
                </group>
              </group>
            </page>

            <page string="Notes" name="notes">
              <field name="notes" placeholder="Notes sur la police..."/>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!--  VUE LISTE — Polices                                                    -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <record id="view_insurance_policy_tree" model="ir.ui.view">
    <field name="name">insurance.policy.tree</field>
    <field name="model">insurance.policy</field>
    <field name="arch" type="xml">
      <tree decoration-muted="state == 'canceled'"
            decoration-danger="state in ('expired','unpaid')"
            decoration-success="state == 'active'">
        <field name="num_police"/>
        <field name="partner_id"/>
        <field name="company_ins_id"/>
        <field name="branche"/>
        <field name="date_effect"/>
        <field name="date_echeance"/>
        <field name="jours_avant_echeance"
               decoration-danger="jours_avant_echeance &lt; 0"
               decoration-warning="jours_avant_echeance &lt;= 30 and jours_avant_echeance &gt;= 0"
               optional="show"/>
        <field name="prime_nette" widget="monetary"
               options="{'currency_field': 'currency_id'}"/>
        <field name="total_impaye" widget="monetary"
               options="{'currency_field': 'currency_id'}"
               decoration-danger="total_impaye &gt; 0"
               optional="show"/>
        <field name="commercial_id" optional="hide"/>
        <field name="agence_courtier" optional="hide"/>
        <field name="state" widget="badge"
               decoration-success="state == 'active'"
               decoration-warning="state == 'unpaid'"
               decoration-danger="state in ('expired','canceled')"/>
        <field name="currency_id" column_invisible="1"/>
      </tree>
    </field>
  </record>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!--  VUE KANBAN — Polices par état                                          -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <record id="view_insurance_policy_kanban" model="ir.ui.view">
    <field name="name">insurance.policy.kanban</field>
    <field name="model">insurance.policy</field>
    <field name="arch" type="xml">
      <kanban default_group_by="state" quick_create="false">
        <field name="num_police"/>
        <field name="partner_id"/>
        <field name="company_ins_id"/>
        <field name="branche"/>
        <field name="date_echeance"/>
        <field name="prime_nette"/>
        <field name="total_impaye"/>
        <field name="state"/>
        <field name="currency_id"/>
        <templates>
          <t t-name="kanban-box">
            <div class="oe_kanban_global_click o_kanban_record">
              <div class="o_kanban_record_top">
                <strong><field name="num_police"/></strong>
                <span class="badge ms-1"><field name="company_ins_id"/></span>
              </div>
              <div class="o_kanban_record_body">
                <div><i class="fa fa-user-o"/> <field name="partner_id"/></div>
                <div class="mt-1 text-muted small">
                  <field name="branche"/> —
                  Ech. <field name="date_echeance"/>
                </div>
                <div class="mt-2 fw-bold">
                  <field name="prime_nette" widget="monetary"
                         options="{'currency_field': 'currency_id'}"/>
                </div>
                <div class="text-danger small" t-if="record.total_impaye.raw_value &gt; 0">
                  Impayé : <field name="total_impaye" widget="monetary"
                                  options="{'currency_field': 'currency_id'}"/>
                </div>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!--  VUE RECHERCHE — Polices                                                -->
  <!-- ═══════════════════════════════
══ -->
  <record id="view_insurance_policy_search" model="ir.ui.view">
    <field name="name">insurance.policy.search</field>
    <field name="model">insurance.policy</field>
    <field name="arch" type="xml">
      <search string="Rechercher une police">
        <field name="num_police" string="N° Police"/>
        <field name="partner_id" string="Assuré"/>
        <field name="company_ins_id" string="Compagnie"/>
        <filter string="Actives" name="active_policies"
                domain="[('state', '=', 'active')]"/>
        <filter string="Brouillons OCR" name="draft_ocr"
                domain="[('state', '=', 'draft_ocr')]"/>
        <filter string="Impayées" name="unpaid"
                domain="[('state', '=', 'unpaid')]"/>
        <filter string="Echéance 30j" name="renewal_30"
                domain="[('jours_avant_echeance', '&lt;=', 30),
                          ('jours_avant_echeance', '&gt;=', 0)]"/>
        <separator/>
        <filter string="Auto" name="auto" domain="[('branche','=','AUTO')]"/>
        <filter string="Sante" name="sante" domain="[('branche','=','SANTE')]"/>
        <group expand="0" string="Regrouper par">
          <filter string="Compagnie" name="grp_company"
                  context="{'group_by': 'company_ins_id'}"/>
          <filter string="Etat" name="grp_state"
                  context="{'group_by': 'state'}"/>
          <filter string="Branche" name="grp_branche"
                  context="{'group_by': 'branche'}"/>
        </group>
      </search>
    </field>
  </record>

</odoo>
