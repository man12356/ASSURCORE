<?xml version="1.0" encoding="utf-8"?>
<!--
================================================================================
  AssurCore — Dashboard Trésorerie
  Référence maquette : deck2.pdf pages 02, 03

  Architecture Odoo native (zéro JSX / zéro React) :

  PAGE 02 — Dashboard Trésorerie :
    ┌─────────────────────────────────────────────────────────────┐
    │  SOLDE CAISSE │ IMPAYÉS >30J │ RENOUVELLEMENTS │ PROD. MTD │  ← <dashboard> + <aggregate>
    ├──────────────────────────────┬──────────────────────────────┤
    │  Pipeline quittances (Kanban)│  Top Impayés (List)          │  ← vue kanban groupée
    │  Émise→Notifiée→…→Reversée  │  trié par retard décrois.    │
    └──────────────────────────────┴──────────────────────────────┘

  PAGE 03 — Quittances Tree Dense :
    Groupé par compagnie, sous-totaux HT/TTC/Commission, badges état

  Vues utilisées :
    1. <dashboard>   sur insurance.receipt  → 4 KPI agrégats natifs Odoo
    2. <kanban>      sur insurance.receipt  → Pipeline groupé par state
    3. <tree>        sur insurance.receipt  → Top Impayés dense (page 03)
    4. <search>      sur insurance.receipt  → Filtres trésorerie
================================================================================
-->
<odoo>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!--  1. VUE RECHERCHE — insurance.receipt (partagée par toutes les vues)  -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <record id="view_insurance_receipt_search" model="ir.ui.view">
    <field name="name">insurance.receipt.search</field>
    <field name="model">insurance.receipt</field>
    <field name="arch" type="xml">
      <search string="Rechercher une quittance">

        <field name="name" string="N° Quittance"/>
        <field name="partner_id" string="Assuré"/>
        <field name="payer_id" string="Payeur"/>
        <field name="policy_id" string="Police"/>
        <field name="company_ins_id" string="Compagnie"/>

        <!-- ── Filtres Trésorerie ─────────────────────────────────────────── -->
        <filter string="Impayées > 30 j" name="overdue_30"
                domain="[('is_overdue', '=', True), ('jours_retard', '&gt;', 30)]"/>
        <filter string="Impayées > 60 j" name="overdue_60"
                domain="[('is_overdue', '=', True), ('jours_retard', '&gt;', 60)]"/>
        <filter string="Contentieux" name="contentieux"
                domain="[('state', '=', 'contentieux')]"/>
        <separator/>
        <filter string="Encaissées" name="encaissees"
                domain="[('state', '=', 'encaissee')]"/>
        <filter string="Reversées" name="reversees"
                domain="[('state', '=', 'reversee')]"/>
        <separator/>
        <!-- Renouvellements à 30 jours — lien avec la police parente -->
        <filter string="Échéance ≤ 30 j" name="echeance_30"
                domain="[('date_echeance', '&lt;=', (context_today() + datetime.timedelta(days=30)).strftime('%Y-%m-%d')),
                         ('date_echeance', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
        <filter string="Ce mois" name="ce_mois"
                domain="[('date_emission', '&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>

        <!-- ── Filtres Branches ──────────────────────────────────────────── -->
        <separator/>
        <filter string="Automobile" name="auto"   domain="[('branche', '=', 'AUTO')]"/>
        <filter string="Santé"      name="sante"  domain="[('branche', '=', 'SANTE')]"/>
        <filter string="MRH"        name="mrh"    domain="[('branche', '=', 'MRH')]"/>

        <!-- ── Groupements ──────────────────────────────────────────────── -->
        <group expand="0" string="Regrouper par">
          <filter string="État"       name="group_state"
                  context="{'group_by': 'state'}"/>
          <filter string="Compagnie"  name="group_compagnie"
                  context="{'group_by': 'company_ins_id'}"/>
          <filter string="Branche"    name="group_branche"
                  context="{'group_by': 'branche'}"/>
          <filter string="Commercial" name="group_commercial"
                  context="{'group_by': 'commercial_id'}"/>
          <filter string="Mois"       name="group_mois"
                  context="{'group_by': 'date_emission:month'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!--  2. VUE DASHBOARD — 4 KPI Trésorerie (Odoo native dashboard view)     -->
  <!--     Maquette page 02 : Solde Caisse · Impayés >30j · Renouv. · MTD   -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
