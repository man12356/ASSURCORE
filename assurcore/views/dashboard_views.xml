          <aggregate name="kpi_impayes_30j" field="amount_residual" string="Impayés &gt; 30 j (TND)" domain="[('is_overdue', '=', True), ('jours_retard', '&gt;', 30)]" group_operator="sum" widget="monetary" help="Montant total des quittances impayées depuis plus de 30 jours."/>
          <aggregate name="kpi_echeances_30j" field="id" string="Renouvellements ≤ 30 j" domain="[('state', 'in', ('emise','notifiee','partielle')), ('date_echeance', '&gt;=', context_today().strftime('%Y-%m-%d'))]" group_operator="count" help="Nombre de quittances arrivant à échéance dans les 30 prochains jours."/>
